import math
xC = float(input("Nhập xC: "))
yC = float(input("Nhập yC: "))
R  = float(input("Nhập bán kính R: "))
xM = float(input("Nhập xM: "))
yM = float(input("Nhập yM: "))
CM = math.sqrt((xM - xC)**2 + (yM - yC)**2)
if CM < R:
    print("M nằm trong đường tròn")
elif CM == R:
    print("M nằm trên đường tròn")
else:
    print("M nằm ngoài đường tròn")
